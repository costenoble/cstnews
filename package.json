{
  "name": "cstlab",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:client": "vite build",
    "build:server": "vite build --ssr src/entry-server.jsx --outDir .prerender",
    "prerender": "node scripts/prerender.mjs",
    "build": "npm run build:client && npm run build:server && npm run prerender",
